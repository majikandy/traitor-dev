{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "/Users/majikandy/Dev/traitordev/scripts/version-on-commit.sh"
          },
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "/Users/majikandy/Dev/traitordev/scripts/version-on-push.sh"
          }
        ]
      }
    ]
  }
}
